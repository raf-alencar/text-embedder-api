# Ollama
OLLAMA_BASE_URL=http://your-ollama-host:11434
# API key forwarded as X-API-Key to Ollama (e.g. Caddy gateway auth). Leave blank if Ollama is unprotected.
OLLAMA_API_KEY=
EMBED_MODEL=nomic-embed-text
EMBED_DIMENSIONS=768

# Auth (SHA-256 hex of raw admin key)
# Generate with: echo -n "your-raw-key" | sha256sum
# Leave blank to disable auth (dev mode)
API_KEY_HASH=

# Service
PORT=3000
