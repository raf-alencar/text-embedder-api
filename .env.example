# OpenRouter
OPENROUTER_API_KEY=
# Override only if using a self-hosted gateway in front of OpenRouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Embedding model (open-weight, multilingual, 32K context, 2560-dim)
# Lock-in choice — changing this invalidates all existing vectors.
EMBED_MODEL=qwen/qwen3-embedding-4b
EMBED_DIMENSIONS=2560

# Auth (SHA-256 hex of raw admin key)
# Generate with: echo -n "your-raw-key" | sha256sum
# Leave blank to disable auth (dev mode)
API_KEY_HASH=

# Service
PORT=3000
